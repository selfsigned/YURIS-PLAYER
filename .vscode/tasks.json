{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "meson: compile",
      "type": "shell",
      "command": "meson compile -C build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "meson: compile (debug)",
      "type": "shell",
      "command": "meson setup build --reconfigure -Dbuildtype=debug && meson compile -C build",
      "group": { "kind": "build", "isDefault": false },
      "problemMatcher": []
    }
  ]
}
